FROM python:3.11-slim

RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN git clone https://github.com/jayrajpamnani/MLOps-Serving.git /repo

RUN pip install --no-cache-dir -r /repo/serving/requirements.txt

RUN cp -r /repo/serving/app /app/app

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
